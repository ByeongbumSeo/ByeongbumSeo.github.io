---
import type { Post } from "../lib/posts";
import { postUrl } from "../lib/posts";

interface Props {
  post: Post;
  posts: Post[];
}

const { post, posts } = Astro.props;
const series = post.data.series;
const index = series ? posts.findIndex((item) => item.data.slug === post.data.slug) : -1;
const previous = index > 0 ? posts[index - 1] : undefined;
const next = index >= 0 && index < posts.length - 1 ? posts[index + 1] : undefined;
---

{
  series && (
    <aside class="series-box" aria-label={`${series.title} 시리즈`}>
      <div>
        <span>Series</span>
        <strong><a class="series-box__title" href={`/series/${series.slug}/`}>{series.title}</a></strong>
        <small>{series.order} / {posts.length}</small>
      </div>
      <nav aria-label={`${series.title} 시리즈 글 이동`}>
        {previous ? <a href={postUrl(previous)}>이전: {previous.data.title}</a> : <span />}
        {next ? <a href={postUrl(next)}>다음: {next.data.title}</a> : <span />}
      </nav>
    </aside>
  )
}
