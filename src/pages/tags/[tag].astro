---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import { getAllTags, getPublishedPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return getAllTags(posts).map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((post) => post.data.tags.includes(tag)) }
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`Tag: ${tag}`} description={`${tag} 태그가 붙은 글 목록입니다.`}>
  <section class="page-heading">
    <p class="eyebrow"><a href="/tags/">Tags</a></p>
    <h1>{tag}</h1>
    <p>{posts.length}개의 글이 있습니다.</p>
  </section>
  <PostList posts={posts} />
</BaseLayout>
