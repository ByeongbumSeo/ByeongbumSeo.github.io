---
import type { Post } from "../lib/posts";
import { formatDate, postUrl } from "../lib/posts";
import { SECTION_LABELS } from "../lib/site";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div class="post-list">
  {
    posts.map((post) => (
      <article class="post-row">
        <div class="post-row__meta">
          <span>{SECTION_LABELS[post.data.kind]}</span>
          <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
        </div>
        <h2><a href={postUrl(post)}>{post.data.title}</a></h2>
        <p>{post.data.description}</p>
        <div class="tag-list">
          {post.data.tags.slice(0, 5).map((tag) => <a href={`/tags/${tag}/`}>{tag}</a>)}
        </div>
      </article>
    ))
  }
</div>
