---
import type { Post } from "../lib/posts";
import { formatDate, postUrl } from "../lib/posts";
import { SECTION_LABELS, SECTION_PATHS } from "../lib/site";
import { categoryPath, getCategory } from "../lib/taxonomy";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div class="post-list">
  {
    posts.map((post) => (
      <article class="post-row">
        <div class="post-row__meta">
          <a href={SECTION_PATHS[post.data.kind]}>
            {SECTION_LABELS[post.data.kind]}
          </a>
          <span aria-hidden="true">/</span>
          <a href={categoryPath(post.data.kind, post.data.category)}>
            {getCategory(post.data.kind, post.data.category)?.label ?? post.data.category}
          </a>
          <span aria-hidden="true">·</span>
          <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
        </div>
        <h2><a href={postUrl(post)}>{post.data.title}</a></h2>
        <p>{post.data.description}</p>
        <div class="tag-list">
          {post.data.tags.slice(0, 5).map((tag) => <a href={`/tags/${tag}/`}>{tag}</a>)}
        </div>
      </article>
    ))
  }
</div>
