---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { getPublishedPosts, getRelatedPosts, getSeriesPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const posts = await getPublishedPosts();
const relatedPosts = getRelatedPosts(post, posts);
const seriesPosts = getSeriesPosts(post, posts);
---

<PostLayout post={post} headings={headings} relatedPosts={relatedPosts} seriesPosts={seriesPosts}>
  <Content />
</PostLayout>
